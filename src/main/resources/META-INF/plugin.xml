<idea-plugin>
    <id>com.mbk.aiassistant</id>
    <name>AI Context Assistant</name>
    <vendor url="https://github.com/musaberkay">Musa Berkay Kocabasoglu</vendor>
    <description><![CDATA[
        Explains selected code using Claude AI with full IDE context awareness.<br><br>
        <b>Usage:</b> Select any code, then right-click → <i>Ask AI about This</i> (or press Ctrl+Alt+A).<br><br>
        The plugin automatically includes the file name, language, and project name in the prompt,
        so Claude answers with context specific to your codebase — not just the snippet in isolation.<br><br>
        Set your Claude API key under <i>Settings → Tools → AI Context Assistant</i>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="AI Assistant"
                    secondary="true"
                    anchor="right"
                    icon="AllIcons.Actions.Find"
                    factoryClass="com.mbk.aiassistant.toolwindow.AIToolWindowFactory"/>

        <applicationService serviceImplementation="com.mbk.aiassistant.api.ClaudeClient"/>
        <applicationService serviceImplementation="com.mbk.aiassistant.settings.PluginSettings"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.mbk.aiassistant.settings.PluginSettingsConfigurable"
                id="com.mbk.aiassistant.settings"
                displayName="AI Context Assistant"/>
    </extensions>

    <actions>
        <action id="com.mbk.aiassistant.AskAI"
                class="com.mbk.aiassistant.actions.AskAIAction"
                text="Ask AI about This"
                description="Explain the selected code using Claude AI with IDE context">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt A"/>
        </action>
    </actions>
</idea-plugin>
