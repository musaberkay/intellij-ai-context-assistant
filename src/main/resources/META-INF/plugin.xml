<idea-plugin>
    <id>com.mbk.aiassistant</id>
    <name>AI Context Assistant</name>
    <vendor url="https://github.com/musaberkay">Musa Berkay Kocabasoglu</vendor>
    <description><![CDATA[
        A chat assistant inside IntelliJ IDEA powered by any OpenAI-compatible model
        (Ollama, LM Studio, OpenAI, Groq) or the Claude API.<br><br>
        <b>Usage:</b> Select code → right-click → <i>Ask AI about This</i> (Ctrl+Alt+A),
        or type directly in the AI Assistant panel.<br><br>
        Configure your provider and model under <i>Settings → Tools → AI Context Assistant</i>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="AI Assistant"
                    secondary="true"
                    anchor="right"
                    icon="AllIcons.Actions.Find"
                    factoryClass="com.mbk.aiassistant.toolwindow.AIToolWindowFactory"/>

        <applicationService serviceImplementation="com.mbk.aiassistant.settings.PluginSettings"/>

        <projectService serviceImplementation="com.mbk.aiassistant.chat.ChatSessionManager"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.mbk.aiassistant.settings.PluginSettingsConfigurable"
                id="com.mbk.aiassistant.settings"
                displayName="AI Context Assistant"/>
    </extensions>

    <actions>
        <action id="com.mbk.aiassistant.AskAI"
                class="com.mbk.aiassistant.actions.AskAIAction"
                text="Ask AI about This"
                description="Send selected code to the AI Assistant chat panel">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt A"/>
        </action>
    </actions>
</idea-plugin>
